{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docs",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["docs:dev"],
      "port": 3005
    },
    {
      "name": "storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "apps/storybook", "exec", "storybook", "dev", "--ci", "--port", "$PORT"],
      "port": 6006,
      "autoPort": true
    }
  ]
}
